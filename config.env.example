# ── Layer A: Azure Content Understanding (PDF path) ─────────────────────────
AZURE_CU_ENDPOINT=https://<your-resource>.services.ai.azure.com/
AZURE_CU_API_KEY=

# ── Layer A: Azure Document Intelligence (image path) ───────────────────────
AZURE_DI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_DI_API_KEY=

# ── Layer A: Default extractor (azure_cu | docling) ──────────────────────────
DEFAULT_EXTRACTOR=azure_cu

# ── Layer D: Qdrant ───────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=medical_docs

# ── Layer E: LLM ─────────────────────────────────────────────────────────────
# LLM_PROVIDER=gemma3   # gemma3 | openai | stub
# GEMMA3_ENDPOINT=http://localhost:8000/v1
# OPENAI_API_KEY=
